# Пример vhost для cryptomarsmedia.ru + Next.js за reverse proxy.
# Не коммитить реальные пути к ключам — скопируйте на сервер и отредактируйте.
#
# Установка на VPS:
#   sudo cp docs/nginx-cryptomarsmedia.conf.example /etc/nginx/sites-available/cryptomarsmedia
#   (или вставьте содержимое в существующий файл вместо старых блоков server для домена)
#   sudo ln -sf /etc/nginx/sites-available/cryptomarsmedia /etc/nginx/sites-enabled/cryptomarsmedia
#   sudo nginx -t && sudo systemctl reload nginx
#
# ОБЯЗАТЕЛЬНО замените:
#   - ssl_certificate / ssl_certificate_key — на ваши строки из Certbot (см. текущий конфиг)
#   - proxy_pass порт — тот, где слушает PM2/next start (часто 3000)

# Редирект с HTTP на HTTPS (если Certbot уже выписал сертификат)
server {
    listen 80;
    listen [::]:80;
    server_name cryptomarsmedia.ru www.cryptomarsmedia.ru;

    client_max_body_size 20M;

    # Certbot обычно добавляет root для ACME; оставьте свой блок, если он уже есть:
    # location ^~ /.well-known/acme-challenge/ { ... }

    return 301 https://$host$request_uri;
}

server {
    # Ubuntu/nginx 1.24: http2 в listen; на nginx 1.25+ можно отдельной строкой http2 on;
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name cryptomarsmedia.ru www.cryptomarsmedia.ru;

    # Без этого большие загрузки (обложки) снова получат HTTP 413
    client_max_body_size 20M;

    # --- замените на ваши пути от Certbot ---
    ssl_certificate     /etc/letsencrypt/live/cryptomarsmedia.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cryptomarsmedia.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300s;
    }
}
