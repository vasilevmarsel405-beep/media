# =============================================================================
# ШАБЛОН: скопируйте в .env.local (разработка) и/или .env.production (VPS/прод).
# Реальные ключи НИКОГДА не коммитьте. Прод на своём сервере: docs/VPS-ENV.ru.md
# Проверка: npm run env:check
# См. docs/SECRETS.ru.md
# =============================================================================

# Публичный URL сайта (без слэша в конце)
NEXT_PUBLIC_SITE_URL=https://your-domain.ru

# Доп. хосты картинок для next/image (Make/CDN), через запятую — без https://
# Пример: cdn.example.com   (mcp-kv.ru уже в next.config.ts)
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=

# RSS подкаста (Mave и др.): полный URL фида — страница /podkasty подтянет выпуски автоматически
# PODCAST_RSS_URL=https://feeds.example.com/your-show.xml
# Интервал кеша Next.js при запросе RSS (секунды, не меньше 60). По умолчанию 600.
# PODCAST_RSS_REVALIDATE_SECONDS=600
# Ссылка на альбом в Яндекс.Музыке (по умолчанию зашита в коде)
# NEXT_PUBLIC_PODCAST_YANDEX_URL=https://music.yandex.ru/album/27001794

# Хранилище материалов:
# - upstash (по умолчанию, если заданы UPSTASH_*),
# - local (локальный файл .local/remote-posts.json на VPS),
# - off (только материалы из кода, без записи из админки/Make).
# POSTS_STORAGE_MODE=local
#
# Upstash Redis (опционально) — REST URL и TOKEN из https://console.upstash.com (раздел REST API)
# Если используете local-режим на VPS, эти две переменные можно не задавать.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Таймаут чтения ленты из Redis (мс). При тупняке сети — иначе страница может висеть очень долго (SDK по умолчанию много ретраев).
# REDIS_READ_TIMEOUT_MS=12000
# Сколько HTTP-повторов к Upstash (0–5). По умолчанию 2.
# UPSTASH_REDIS_RETRIES=2
# Полностью отключить локальный файл как fallback (обычно не нужно):
# DISABLE_LOCAL_POSTS_FILE=1

# Лента материалов на сайте: по умолчанию — статика из кода + облако (облако перезаписывает slug).
# remote_only — на сайте только посты из Redis/Make; демо из content.ts не показываются (см. posts-service).
# POSTS_FEED_MODE=remote_only

# Кеш массива постов в памяти процесса (мс). Меньше обращений к Upstash при частых заходах.
# POSTS_MEMORY_CACHE_MS=60000
# (ISR страниц с лентой — литерал revalidate в src/app/**/page.tsx, см. posts-cache-config.ts)

# Случайная длинная строка (сгенерируйте сами). Тот же текст — в Make и на хостинге.
MAKE_WEBHOOK_SECRET=
# Webhook по умолчанию только пишет Redis + сбрасывает память ленты (без revalidatePath — иначе VPS зависает).
# Посты на сайте подтягиваются по ISR (сейчас 120 с на основных страницах — см. export const revalidate в app/).
# Опасно для прод: включить принудительный revalidate маршрутов из Make:
# MAKE_WEBHOOK_REVALIDATE_PATHS=1
# Если включили revalidate путей — «лёгкий» набор путей (по умолчанию) или полный:
# MAKE_WEBHOOK_LIGHT_REVALIDATE=0

# YouTube Data API v3 — полное описание и автозаполнение в админке. На VPS продублируйте в .env.production (не только в .env.local).
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# YOUTUBE_DATA_API_KEY=

# Админка. В dev без ADMIN_PASSWORD допускается пароль 1234 (см. код).
ADMIN_PASSWORD=
# Минимум 16 символов
ADMIN_SESSION_SECRET=

# После стабильного HTTPS:
# ENABLE_HSTS=1

# --- Яндекс.Метрика ---
# Номер счётчика (цифры) — для счётчика на сайте и для API, если нет YANDEX_METRIKA_COUNTER_ID
NEXT_PUBLIC_YANDEX_METRIKA_ID=
# OAuth-токен (только сервер): отчёты в админке. Не NEXT_PUBLIC. Создать: yandex.ru/dev
YANDEX_METRIKA_OAUTH_TOKEN=
# Опционально: ID счётчика только для API (если отличается от публичного)
# YANDEX_METRIKA_COUNTER_ID=
# NEXT_PUBLIC_YANDEX_VERIFICATION=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
